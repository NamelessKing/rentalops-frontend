# .env.local.example
#
# Copy this file to .env.local and fill in the values for your local environment.
# .env.local is git-ignored (*.local pattern in .gitignore) — never commit real values.
#
# Usage:
#   cp .env.local.example .env.local
#
# Required variables:

# Base URL of the Spring Boot backend (Slice 0: local dev server)
VITE_API_BASE_URL=http://localhost:8080

# Local frontend dev server host and port (Vite)
VITE_DEV_SERVER_HOST=127.0.0.1
VITE_DEV_SERVER_PORT=5173
